{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://omega-synth.dev/schema/module-schema-7.0.json",
  "title": "OMEGA Module Schema (Era 7.0 Industrial)",
  "type": "object",
  "required": ["schemaVersion", "id", "metadata", "ui", "resources"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["7.0"]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "family"],
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "version": { "type": "string" },
        "description": {
          "type": "string",
          "description": "Short technical summary of the module's purpose"
        },
        "status": {
          "type": "string",
          "enum": ["stable", "beta", "experimental", "deprecated"],
          "default": "experimental"
        },
        "family": { 
          "type": "string",
          "enum": ["osc", "filter", "env", "lfo", "vca", "fx", "utility", "io", "sequencer", "expert", "telemetry"],
          "description": "Technical family of the module (categorization)"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rack": {
          "type": "object",
          "properties": {
            "slot": { "type": "string", "enum": ["top", "main"] },
            "height_mode": { "type": "string", "enum": ["full", "compact"] },
            "hp": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "ui": {
      "type": "object",
      "required": ["dimensions", "controls"],
      "properties": {
        "dimensions": {
          "type": "object",
          "properties": {
            "width": { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "skin": { "type": "string" },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "bind", "pos"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "bind": { "type": "string" },
              "label": { "type": "string" },
              "pos": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "presentation": {
                "type": "object",
                "properties": {
                  "tab": { "type": "string", "enum": ["MAIN", "PATCHING", "SETUP", "MIDI", "ADVANCED"], "default": "MAIN" },
                  "component": { 
                    "type": "string",
                    "enum": ["knob", "slider-v", "slider-h", "select", "display", "switch", "button", "port", "led", "hidden"]
                  },
                  "variant": { "type": "string", "description": "Official OMEGA variant string (e.g. A_red, B_cyan_5mm)" },
                  "attachments": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "type": "string", "enum": ["label", "led", "display"] },
                        "position": { "type": "string", "enum": ["top", "bottom", "left", "right"] },
                        "role": { "type": "string" },
                        "bind": { "type": "string" },
                        "offset": { "type": "integer", "default": 0 },
                        "text": { "type": "string" },
                        "unit": { "type": "string" },
                        "format": {
                          "type": "object",
                          "properties": {
                            "decimals": { "type": "integer" },
                            "prefix": { "type": "string" },
                            "suffix": { "type": "string" }
                          }
                        }
                      }
                    }
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": { "type": "string" },
                        "value": { "type": "number" }
                      }
                    }
                  },
                  "unit": { "type": "string" },
                  "precision": { "type": "integer" },
                  "ui_precision": { "type": "integer" }
                }
              }
            }
          }
        },
        "jacks": {
          "type": "array",
          "items": { "$ref": "#/properties/ui/properties/controls/items" }
        }
      }
    },
    "resources": {
      "type": "object",
      "required": ["wasm"],
      "properties": {
        "wasm": { "type": "string" },
        "contract": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
